{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "baseCurrency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "baseCurrency"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A collection of expenses for a specific trip",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An individual expense entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "tripId": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "convertedAmount": { "type": "number" },
        "exchangeRate": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "notes": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "amount", "currency", "convertedAmount", "date", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Expense categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User records"
    },
    "trips": {
      "schema": "Trip",
      "description": "User trips"
    },
    "expenses": {
      "schema": "Expense",
      "description": "Expense records"
    },
    "categories": {
      "schema": "Category",
      "description": "User custom categories"
    }
  }
}
